{
  "name": "@vercel-labs/up",
  "version": "0.1.0",
  "description": "Instant, shareable dev environments on Vercel Sandbox",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vercel-labs/upcli.git",
    "directory": "packages/cli"
  },
  "homepage": "https://upcli.dev",
  "keywords": [
    "vercel",
    "sandbox",
    "development",
    "dev-server"
  ],
  "type": "module",
  "bin": {
    "up": "./dist/cli.js"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "private": true,
  "scripts": {
    "build": "tsup && node scripts/check-bundle-size.mjs",
