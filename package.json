{
  "name": "upcli-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter up dev",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check",
    "format": "biome check --write"
  },
  "pnpm": {
    "overrides": {
      "js-yaml@3.13.1": "3.14.2",
      "js-yaml@4.1.0": "4.1.1",
      "minimatch@3.1.2": "3.1.4",
      "minimatch@10.1.1": "10.2.3",
      "smol-toml@1.5.2": "1.6.1"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "typescript": "^5.8.3"
  }
}
